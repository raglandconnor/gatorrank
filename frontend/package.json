{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:webpack": "next dev --webpack --hostname 0.0.0.0 --port 3000",
    "dev:port": "sh -c 'next dev --hostname 0.0.0.0 --port ${PORT:-3000}'",
    "dev:webpack:port": "sh -c 'next dev --webpack --hostname 0.0.0.0 --port ${PORT:-3000}'",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test": "bun run test:unit && bun run test:e2e"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.32.0",
    "@emotion/react": "^11.14.0",
    "framer-motion": "^12.34.2",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5",
    "vitest": "^4.1.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
